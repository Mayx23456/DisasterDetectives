<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controller.WinScreenController" alignment="CENTER" spacing="16.0" prefWidth="900.0" prefHeight="600.0">
    <padding>
        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
    </padding>

    <Label text="Game Over" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
    <Label fx:id="winnerLabel" text="Winner" style="-fx-font-size: 18px;"/>

    <HBox spacing="12.0" alignment="CENTER">
        <Button text="Main Menu" onAction="#handleMainMenu" prefWidth="140.0"/>
        <Button text="Exit" onAction="#handleExit" prefWidth="140.0"/>
    </HBox>
</VBox>
