<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="controller.DisasterDialogController" spacing="12.0" alignment="CENTER" prefWidth="420.0" prefHeight="300.0">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>
    <Label fx:id="questionLabel" wrapText="true" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <Button fx:id="optionA" onAction="#handleOptionA" prefWidth="360.0"/>
    <Button fx:id="optionB" onAction="#handleOptionB" prefWidth="360.0"/>
    <Button fx:id="optionC" onAction="#handleOptionC" prefWidth="360.0"/>
    <Button fx:id="optionD" onAction="#handleOptionD" prefWidth="360.0"/>
</VBox>
